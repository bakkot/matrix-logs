{"content":{"body":"A mictotask check point only takes effect when the js stack is empty. When you call dispatchEvent from within a script you are still inside a js stack ","m.relates_to":{"event_id":"$J5oBFMPGzUjAGpP1jhoTbulgJNktJ1RZKOpr_NMEi78","is_falling_back":true,"m.in_reply_to":{"event_id":"$J5oBFMPGzUjAGpP1jhoTbulgJNktJ1RZKOpr_NMEi78"},"rel_type":"m.thread"},"msgtype":"m.text"},"ts":1774854979353,"senderName":"Noam Rosenthal","senderId":"@noamr:matrix.org","id":"$W5l0KQ2xQAnQORVinMJElKWaLGI1I0HvrKkKopyhjuc"},
